// TEST: Match expressions

foreign exit :: (code: i32)

main :: () -> i32 {
    x := 2
    result := match x {
        0 => 100
        1 => 200
        2 => 300
        _ => 999
    }
    if result != 300 {
        exit(1)
    }

    y := 99
    result2 := match y {
        0 => 0
        1 => 1
        _ => -1
    }
    if result2 != -1 {
        exit(2)
    }

    return 0
}
