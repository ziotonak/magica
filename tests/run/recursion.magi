// TEST: Recursive functions

foreign exit :: (code: i32)

factorial :: (n: i32) -> i32 {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fib :: (n: i32) -> i32 {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

main :: () -> i32 {
    if factorial(5) != 120 {
        exit(1)
    }

    if factorial(10) != 3628800 {
        exit(2)
    }

    if fib(10) != 55 {
        exit(3)
    }

    return 0
}
