// TEST: Float comparisons

foreign exit :: (code: i32)

main :: () -> i32 {
    a := 3.14
    b := 2.71
    c := 3.14

    if !(b < a) {
        exit(1)
    }

    if !(a > b) {
        exit(2)
    }

    if !(a == c) {
        exit(3)
    }

    if !(a != b) {
        exit(4)
    }

    neg := -1.5
    pos := 1.5
    if !(neg < pos) {
        exit(5)
    }

    return 0
}
