// TEST: Bitwise operators (AND, OR, XOR, shifts)

foreign exit :: (code: i32)

main :: () -> i32 {
    a : i32 = 0xFF00
    b : i32 = 0x0FF0

    c := a & b
    if c != 0x0F00 {
        exit(1)
    }

    d := a | b
    if d != 0xFFF0 {
        exit(2)
    }

    e := a ^ b
    if e != 0xF0F0 {
        exit(3)
    }

    f : i32 = 1
    g := f << 4
    if g != 16 {
        exit(4)
    }

    h : i32 = 256
    i := h >> 4
    if i != 16 {
        exit(5)
    }

    return 0
}
